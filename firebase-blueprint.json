{
  "projectInfo": {
    "name": "Island Diary",
    "description": "A journaling and future letter app using Firebase for persistent storage."
  },
  "databaseConfiguration": {
    "firestore": {
      "rules": {
        "collections": [
          {
            "name": "letters",
            "description": "Stores future letters to be delivered.",
            "readAccess": "if true;",
            "writeAccess": "if true;",
            "fields": [
              { "name": "id", "type": "string" },
              { "name": "to", "type": "string" },
              { "name": "subject", "type": "string" },
              { "name": "content", "type": "string" },
              { "name": "deliverAt", "type": "string" },
              { "name": "createdAt", "type": "string" },
              { "name": "status", "type": "string" }
            ]
          },
          {
            "name": "diaries",
            "description": "Stores life diaries and island stats.",
            "readAccess": "if true;",
            "writeAccess": "if true;",
            "fields": [
              { "name": "id", "type": "string" },
              { "name": "content", "type": "string" },
              { "name": "date", "type": "string" }
            ]
          },
          {
            "name": "island_state",
            "description": "Stores global app interactions like comments and likes.",
            "readAccess": "if true;",
            "writeAccess": "if true;",
            "fields": [
              { "name": "id", "type": "string" },
              { "name": "data", "type": "string" }
            ]
          }
        ]
      }
    }
  }
}
